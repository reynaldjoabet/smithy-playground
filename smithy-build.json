{
    "version": "0.1",
    "projections": {
        "public": {
            "transforms": [
                {
                    "name": "excludeByTrait",
                    "args": { "traits": ["internal", "beta"] }
                },
                {
                    "name": "excludeShapesByTag",
                    "args": { "tags": ["admin-only"] }
                }
            ],
            "plugins": {
                "openapi": {
                    "service": "com.unison.identitymanagement#IdentityManagementService"
                }
            }
        },
        "admin": {
            "transforms": [
                {
                    "name": "includeShapesByTag",
                    "args": { "tags": ["admin-only", "shared"] }
                }
            ],
            "plugins": {
                "openapi": {
                    "service": "com.unison.identitymanagement#AdminService"
                }
            }
        }
    },
    "sources": [
        "models/",
        "traits/"
    ],
    "outputDirectory": "output",
    "maven": {
        "dependencies": [
            "software.amazon.smithy:smithy-model:1.58.0",
            "software.amazon.smithy:smithy-utils:1.58.0",
            "software.amazon.smithy:smithy-codegen-core:1.58.0",
            "software.amazon.smithy:smithy-aws-traits:1.58.0",
            "software.amazon.smithy:smithy-aws-apigateway-traits:1.58.0",
            "software.amazon.smithy:smithy-aws-apigateway-openapi:1.58.0",
            "software.amazon.smithy:smithy-aws-cloudformation:1.58.0",
            "software.amazon.smithy:smithy-aws-cloudformation-traits:1.58.0",
            "software.amazon.smithy:smithy-aws-iam-traits:1.58.0",
            "software.amazon.smithy:smithy-aws-endpoints:1.58.0",
            "software.amazon.smithy:smithy-aws-protocol-tests:1.58.0",
            "software.amazon.smithy:smithy-aws-smoke-test-model:1.58.0",
            "software.amazon.smithy:smithy-validation-model:1.58.0",
            "software.amazon.smithy.typescript:smithy-aws-typescript-codegen:0.31.1",
            "software.amazon.smithy:smithy-openapi:1.58.0",
            "software.amazon.smithy.java:client-core:0.0.2",
            "software.amazon.smithy.java.codegen:plugins:0.0.1",
            "software.amazon.smithy.java:aws-client-restjson:0.0.2"
        ]
    },
    "plugins": {
        "typescript-client-codegen": {
            "package": "unison-sdk",
            "packageVersion": "0.0.1"
        },
        "haskell-client-codegen": {
            "namespace": "smithy.haskell.client.codegen.generators",
            "service": "io.unison#Unison",

            "protocol": "aws.protocols#restJson1"
        },
        "scala-client-codegen": {
            "namespace": "smithy.scala.client.codegen.generators",
            "service": "io.unison#Unison",
            "protocol": "aws.protocols#restJson1"
        },
        "openapi": {
            "service": "io.unison#Unison",
            "protocol": "aws.protocols#restJson1",
            "version": "3.0.2",
            "tags": true,
            "supportedTags": [
                "Configuration Management",
                "Context Management",
                "Default Configuration",
                "Dimensions",
                "Experimentation",
                "Experiment Groups",
                "Functions",
                "Organisation Management",
                "Type Templates",
                "Webhooks",
                "Workspace Management",
                "Secrets",
                "Audit & Monitoring",
                "Variables"
            ],
            "defaultBlobFormat": "byte",
            "keepUnusedComponents": false,
            "substitutions": {
                "io.unison#Unison": {
                    "title": "Unison API",
                    "description": "API documentation for Unison"
                }
            }
        }
    }
}